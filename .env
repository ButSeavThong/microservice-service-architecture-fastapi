APP_NAME=profile-service
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# Database — match your docker-compose exactly
DATABASE_URL=postgresql+asyncpg://thong:password@127.0.0.1:4000/mydb
DATABASE_ECHO=true

# Kafka — match your running Kafka broker
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Valkey
VALKEY_URL=redis://localhost:6379/0

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=profile-service